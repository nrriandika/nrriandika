{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/src/(.*)", "dest": "/src/$1" },
    { "src": "/styles.css", "dest": "/styles.css" },
    { "src": "/script.js", "dest": "/script.js" },
    { "src": "/spotify.js", "dest": "/spotify.js" },
    { "src": "/recommendations.js", "dest": "/recommendations.js" },
    { "src": "/(.*)", "dest": "/server.js" }
  ]
}
