# ── Spotify API ─────────────────────────────────────────────────
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/auth/callback

# ── Session ──────────────────────────────────────────────────────
SESSION_SECRET=ganti_dengan_string_random_yang_panjang

# ── Supabase ─────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# ── Anthropic (Haiku — default Song Finder) ─────────────────────
# Dapatkan dari: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxx

# ── Google Gemini (Deep Search with web grounding) ───────────────
# Dapatkan dari: https://aistudio.google.com/apikey
# Bisa pakai multiple keys (comma-separated) untuk handle high demand.
# Setiap key punya quota 250 req/hari — auto rotate kalau satu hit limit.
GEMINI_API_KEYS=key_1,key_2,key_3
# Atau single key (legacy):
# GEMINI_API_KEY=xxxxxxxxxx

# ── ScraperAPI (Book Hunter — Shopee proxy) ──────────────────────
# Dapatkan dari: https://dashboard.scraperapi.com (free 5000 credits)
SCRAPER_API_KEY=xxxxxxxxxx

# ── Cron secret (Vercel Cron auth) ───────────────────────────────
CRON_SECRET=ganti_dengan_string_random_panjang

# ── Server ───────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
